# ---- Server ----
NODE_ENV=production
PORT=3000

# ---- CORS ----
ALLOWED_ORIGIN_1=https://www.letterride.com
ALLOWED_ORIGIN_2=http://localhost:3000

# ---- JWT ----
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_256bit_random_hex
JWT_EXPIRY=8h

# ---- HR Credentials (4 reps) ----
# Generate hash: node -e "require('bcrypt').hash('yourpassword', 12).then(console.log)"
HR_USER_1_NAME=hr.rep1
HR_USER_1_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

HR_USER_2_NAME=hr.rep2
HR_USER_2_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

HR_USER_3_NAME=hr.rep3
HR_USER_3_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

HR_USER_4_NAME=hr.rep4
HR_USER_4_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# ---- Session Tokens ----
SESSION_TOKEN_TTL_MS=600000
